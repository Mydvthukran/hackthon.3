# API Base URL Configuration
#
# For local development: Leave empty or comment out (Vite proxy will handle /api requests)
# For production (Vercel frontend + separate backend): Set to your backend URL
# For monolith deployment (Render): Leave empty (API is on same origin)
#
# Examples:
# VITE_API_BASE_URL=https://your-backend.onrender.com
# VITE_API_BASE_URL=http://localhost:8000
VITE_API_BASE_URL=
